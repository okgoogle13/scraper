{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "eBay AU Hardware Listing Schema",
  "type": "object",
  "properties": {
    "platform": { "type": "string" },
    "listing_id": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "title": { "type": "string" },
    "price_aud": { "type": "number" },
    "seller_name": { "type": "string" },
    "seller_rating": { "type": ["number", "null"] },
    "condition_code": { "type": "string" },
    "condition_label": { "type": "string" },
    "shipping_type": { "type": ["string", "null"] },
    "pickup_location_text": { "type": ["string", "null"] },
    "category_path": { "type": "string" },
    "full_listing_text": { "type": "string" },
    "scraped_at": { "type": "string", "format": "date-time" },
    "gpu_name": { "type": ["string", "null"] },
    "vram_capacity": { "type": ["integer", "null"], "description": "VRAM capacity in gigabytes" },
    "cpu_name": { "type": ["string", "null"] },
    "total_system_ram": { "type": ["integer", "null"], "description": "Total system RAM in gigabytes" },
    "storage": { "type": ["string", "null"] },
    "egpu_model": { "type": ["string", "null"] },
    "touchscreen_digitizer": { "type": ["boolean", "null"] },
    "exact_model_name": { "type": ["string", "null"] }
  },
  "required": [
    "platform",
    "listing_id",
    "url",
    "title",
    "price_aud",
    "seller_name",
    "seller_rating",
    "condition_code",
    "condition_label",
    "shipping_type",
    "pickup_location_text",
    "category_path",
    "full_listing_text",
    "scraped_at",
    "gpu_name",
    "vram_capacity",
    "cpu_name",
    "total_system_ram",
    "storage",
    "egpu_model",
    "touchscreen_digitizer",
    "exact_model_name"
  ]
}
